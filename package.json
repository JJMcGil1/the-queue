{
  "name": "queue",
  "version": "1.1.0",
  "description": "Queue - Your personal media watchlist",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "build": "vite build && electron-builder --publish never",
    "dist": "vite build && electron-builder --publish never",
    "release": "npm run dist && node scripts/generate-release-hash.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "Justin McGill",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "sharp": "^0.34.5",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "build": {
    "appId": "com.queue.app",
    "productName": "Queue",
    "files": [
      "main.js",
      "preload.js",
      "database.js",
      "auto-updater.js",
      "dist/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.entertainment"
    },
    "dmg": {
      "title": "Queue",
      "iconSize": 80,
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  }
}

{
  "name": "the-queue",
  "version": "1.0.0",
  "description": "The Queue - Your personal media watchlist",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build",
    "build": "vite build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "Justin McGill",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "sharp": "^0.34.5",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "build": {
    "appId": "com.justinmcgill.thequeue",
    "productName": "The Queue",
    "files": [
      "main.js",
      "preload.js",
      "database.js",
      "dist/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    }
  }
}
